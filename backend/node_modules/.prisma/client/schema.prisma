generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())

  indicators HealthIndicator[]
}

model HealthIndicator {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Dados do dataset BRFSS 2015 (Kaggle) simplificados
  bmi            Float // IMC
  highBloodPress Boolean // Pressão alta
  highChol       Boolean // Colesterol alto
  smoker         Boolean // Fumante
  physActivity   Boolean // Atividade física
  fruits         Boolean // Consumo de frutas
  veggies        Boolean // Consumo de vegetais

  // Resposta da IA (Preenchido via RabbitMQ depois)
  riskLevel    String? // BAIXO, MEDIO, ALTO
  clusterGroup Int? // Grupo comportamental (K-Means)

  createdAt DateTime @default(now())
}
